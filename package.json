{
  "name": "email-deliverability",
  "version": "0.1.0",
  "description": "Honest email validation, normalization, DNS deliverability checks, and SMTP diagnostics for Node.js and Bun.",
  "type": "module",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/onlyoneaman/email-deliverability.git"
  },
  "bugs": {
    "url": "https://github.com/onlyoneaman/email-deliverability/issues"
  },
  "homepage": "https://github.com/onlyoneaman/email-deliverability#readme",
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "provenance": true,
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./syntax": {
      "types": "./dist/syntax.d.ts",
      "import": "./dist/syntax.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE",
    "CHANGELOG.md",
    "SECURITY.md"
  ],
  "keywords": [
    "email",
    "email-validation",
    "email-validator",
    "email-verification",
    "email-verifier",
    "email-checker",
    "validate-email",
    "mx-records",
    "dns",
    "smtp",
    "disposable-email",
    "free-email",
    "idn",
    "typescript",
    "bun",
    "nodejs"
  ],
  "scripts": {
    "test": "bun test",
    "build": "bun run clean && tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "pack:dry": "npm pack --dry-run",
    "prepack": "bun run build",
    "prepublishOnly": "bun test && bun run typecheck && bun run build"
  },
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "typescript": "^5.9.0"
  }
}
